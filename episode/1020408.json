            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "（初魅さんは、世界演劇リーグを受け入れる気がないから……。/n　しぐれには、たぶんもう……チャンスは来ない）",
