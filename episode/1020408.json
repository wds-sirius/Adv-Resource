        },
        {
            "Id": 1020408003,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 3,
            "SpeakerName": "しぐれの母",
            "FontSize": 2,
            "Phrase": "あら、どうしたのしぐれ？　溜息なんかついて……。",
            "VoiceFileName": "10204080030",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408004,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "えっ！？　しぐれ、溜息なんてついてた？/nマ、ママの聞き間違いよ、きっと……！",
            "VoiceFileName": "10204080040",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 105,
                    "BodyMotionMasterId": 12,
                    "LipSyncMasterId": 1,
                    "SpineId": 20501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020408005,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "しぐれの母",
            "FontSize": 2,
            "Phrase": "そう？　ならいいけど……。/nところで、さっきの話なんだったかしら。",
            "VoiceFileName": "10204080050",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408006,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "同僚がクビになるんだよ……不況の煽りだ、これも仕方あるまい。/n成果の出せない人間は淘汰されるしかないんだ。",
            "VoiceFileName": "10204080060",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408007,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "（成果の出せない人は……やめさせられる……)",
            "VoiceFileName": "10204080070",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 25,
                    "SpineId": 20501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020408008,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "しぐれの母",
            "FontSize": 2,
            "Phrase": "しぐれ、箸が止まっているわよ。/nやっぱり気分が悪いの？",
            "VoiceFileName": "10204080080",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408009,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "だ、大丈夫よ……。",
            "VoiceFileName": "10204080090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 1,
                    "SpineId": 20501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020408010,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "しぐれの母",
            "FontSize": 2,
            "Phrase": "……食事の最中にする話じゃなかったかもしれないわね。/nでも、しぐれもちゃんと聞いておいた方がいいわ。",
            "VoiceFileName": "10204080100",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408011,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "社会というものの厳しさを理解しておくのは大事だ。/n特に今のしぐれは、特殊な環境にいるんだからな。",
            "VoiceFileName": "10204080110",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408012,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "うん、そうよね……。",
            "VoiceFileName": "10204080120",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "HeadMotionMasterId": 1,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 20501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020408013,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "結果も信用も積み上げられなかった者が、/n後から失敗に気付いても遅いんだ。",
            "VoiceFileName": "10204080130",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408014,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "自分の身の振り方は、きちんと考えないといけない。/n迅速な行動が結果に繋がる。",
            "VoiceFileName": "10204080140",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408015,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "しぐれの母",
            "FontSize": 2,
            "Phrase": "無駄にしてしまった時間は返ってこないものね。",
            "VoiceFileName": "10204080150",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408016,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "そういう事だ。",
            "VoiceFileName": "10204080160",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408017,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "しぐれも今は演劇を楽しんでいられる時期かもしれないが、/nそのうち将来の事も、きちんと考えるんだぞ。",
            "VoiceFileName": "10204080170",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408018,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "う、うん……。/nもちろん分かってるわ、パパ。",
            "VoiceFileName": "10204080180",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "HeadMotionMasterId": 1,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 20501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020408019,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "ああ、演劇といえば……人事の者が何か昼休みに話していたな。/n演劇の大きなイベントがあるとか、どうとか。",
            "VoiceFileName": "10204080190",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408020,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "しぐれの母",
            "FontSize": 2,
            "Phrase": "ああ。『ホロスコープシーズン』のことかしら。/n私の周りでも噂になっているわ。",
            "VoiceFileName": "10204080200",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408021,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "っ……！",
            "VoiceFileName": "10204080210",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 500,
                    "BodyMotionMasterId": 13,
                    "SpineId": 20501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020408022,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "しぐれの母",
            "FontSize": 2,
            "Phrase": "詳しいことはよく知らないけど、有望な役者を探して、/n海外から日本の劇団に視察が来るんでしょう？",
            "VoiceFileName": "10204080220",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408023,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "う、うん。そうみたい。",
            "VoiceFileName": "10204080230",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 105,
                    "HeadMotionMasterId": 1,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 20501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020408024,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "お前の劇団では、そういった話は聞かないのか。",
            "VoiceFileName": "10204080240",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408025,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "……特に、ないかな……。",
            "VoiceFileName": "10204080250",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 25,
                    "LipSyncMasterId": 4,
                    "SpineId": 20501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
        {
            "Id": 1020408026,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "しぐれの父",
            "FontSize": 2,
            "Phrase": "そうか。まあ海外からの視察というからには、よほどのことだ。/nそこいらの劇団に与えられる機会ではないだろうな。",
            "VoiceFileName": "10204080260",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 1020408027,
            "EpisodeMasterId": 1020408,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "（パパ……Edenはね、もう『そこいらの劇団』なんかじゃないよ。/n　チャンスはもらえたの……でも……）",
            "VoiceFileName": "10204080270",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 25,
                    "SpineId": 20501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "205"
        },
