            "FadeValue3": 0.20000000298023224
        },
        {
            "Id": 2006707036,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 35,
            "SpeakerName": "観客A",
            "FontSize": 2,
            "Phrase": "すごい、なんて迫力……！/nスサノオが今そこに居るかのように、縦横無尽に駆け回ってる……！！",
            "VoiceFileName": "20067070290",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006707037,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 36,
            "SpeakerName": "観客B",
            "FontSize": 2,
            "Phrase": "スサノオの半生をこのように舞台に落とし込むか……、/n劇団Eden、ここまで地力の高い劇団だったとは……！",
            "VoiceFileName": "20067070550",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006707038,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 37,
            "SpeakerName": "観客Ｃ",
            "FontSize": 2,
            "Phrase": "こんなクオリティの高い演技が、ここで見れるの……！？/nEdenってやっぱりすごい……。",
            "VoiceFileName": "20067070300",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
