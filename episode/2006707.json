            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 38,
            "SpeakerName": "神主",
            "FontSize": 2,
            "Phrase": "なんて素晴らしい演技だ、/nこのような舞台を、奉納することが出来るなんて……！",
            "VoiceFileName": "20067070310",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
