        {
            "Id": 2006707017,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "観客A",
            "FontSize": 2,
            "Phrase": "出張公演だって～、珍しいよね～。/nEdenって前見た公演でも思ったけど、独創的だよね～。",
            "VoiceFileName": "20067070140",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006707018,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "観客Ｂ",
            "FontSize": 2,
            "Phrase": "舎人仁花子はアマテラス、烏森大黒はオオゲツヒメ……。/nEdenによって描かれるスサノオの半生……この公演は見逃せないな。",
            "VoiceFileName": "20067070150",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006707019,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "観客Ｃ",
            "FontSize": 2,
            "Phrase": "『スサノオノミコト』だって、どんな舞台になってるんだろ～。/nあ、始まるよ！",
            "VoiceFileName": "20067070540",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006707020,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『貴方の所業は既に伝え聞いております……』",
            "VoiceFileName": "20067070160",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 2006707021,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『寄る辺を求めてとのことですが、/n　本当はこの高天原を奪取するつもりでは？』",
            "VoiceFileName": "20067070170",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 2006707022,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "仁花子",
            "FontSize": 2,
            "Phrase": "『ああ、だとすればなんと恐ろしい……』",
            "VoiceFileName": "20067070180",
            "CharacterMotions": [],
            "SpeakerIconId": "203"
        },
        {
            "Id": 2006707023,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "『誤解だ、姉上……！　どうすれば、分かってもらえる……！？/n　わかった……！　ならば貴女の為に誓いを結ぼう……！！』",
            "VoiceFileName": "20067070190",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 2006707024,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 23,
            "FontSize": 2,
            "Phrase": "",
            "BackgroundImageFileFadeType": 1,
            "CharacterMotions": [],
            "FadeValue1": 0.20000000298023224,
            "FadeValue2": 0.30000001192092896,
            "FadeValue3": 0.20000000298023224
        },
        {
            "Id": 2006707025,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "『なんだこれは……こんなものを食えと言うのか！？/n　飢えていようとも誇りを捨てるつもりはないぞ！！』",
            "VoiceFileName": "20067070200",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 2006707026,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "大黒",
            "FontSize": 2,
            "Phrase": "『ああ、スサノオ様……そんなつもりじゃ……！/n　ごめんなさい、ごめんなさい！』",
            "VoiceFileName": "20067070210",
            "CharacterMotions": [],
            "SpeakerIconId": "202"
        },
        {
            "Id": 2006707027,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 26,
            "FontSize": 2,
            "Phrase": "",
            "BackgroundImageFileFadeType": 1,
            "CharacterMotions": [],
            "FadeValue1": 0.20000000298023224,
            "FadeValue2": 0.30000001192092896,
            "FadeValue3": 0.20000000298023224
        },
        {
            "Id": 2006707028,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "『あ、なたは……』",
            "VoiceFileName": "20067070220",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 2006707029,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "『キミがクシナダか、キミの両親から頼まれた。/n　信じて待っていてくれ』",
            "VoiceFileName": "20067070230",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 2006707030,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 29,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『巫女だけかと思えば、もう一人エサが来るとは……。/n　我が腹の肥やしとなるがいい！！』",
            "VoiceFileName": "20067070240",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 2006707031,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 30,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "『はぁっ！！！』",
            "BackgroundCharacterImageFileName": "142240_0",
            "VoiceFileName": "20067070250",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 2006707032,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 31,
            "SpeakerName": "しぐれ",
            "FontSize": 2,
            "Phrase": "『なに、なんだその神気は！？　まるで、神の御子……！？/n　……貴様、何を踊っている！？』",
            "BackgroundCharacterImageFileName": "142240_0",
            "VoiceFileName": "20067070260",
            "CharacterMotions": [],
            "SpeakerIconId": "205"
        },
        {
            "Id": 2006707033,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 32,
            "SpeakerName": "容",
            "FontSize": 2,
            "Phrase": "『名も知らぬお方、貴方を信じて私の神気を託します。/n　だから、どうか荒神を打倒してください！』",
            "BackgroundCharacterImageFileName": "142240_0",
            "VoiceFileName": "20067070270",
            "CharacterMotions": [],
            "SpeakerIconId": "204"
        },
        {
            "Id": 2006707034,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 33,
            "SpeakerName": "初魅",
            "FontSize": 2,
            "Phrase": "『あぁ！　我が剣、天羽々斬に誓って！！！』",
            "BackgroundCharacterImageFileName": "142240_0",
            "BgmFileName": "405",
            "VoiceFileName": "20067070280",
            "CharacterMotions": [],
            "SpeakerIconId": "201"
        },
        {
            "Id": 2006707035,
            "EpisodeMasterId": 2006707,
            "Order": 1,
            "GroupOrder": 34,
            "FontSize": 2,
            "Phrase": "",
