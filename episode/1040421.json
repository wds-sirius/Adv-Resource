            "EpisodeMasterId": 1040421,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "蕾",
            "FontSize": 2,
            "Phrase": "良いではないか、本巣。それに少なくともお前も、/n白丸の演技には影響されたところがあるのだろう？",
            "VoiceFileName": "10404210250",
            "CharacterMotions": [
