            "EpisodeMasterId": 1040421,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "電姫劇団員たち",
            "FontSize": 2,
            "Phrase": "「マチコさまからお褒めの言葉が……！」「やったぜー！」/n「恐悦至極……！」「確かに、みんなの演技よかったよねぇー！」",
