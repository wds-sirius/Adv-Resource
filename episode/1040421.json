            "EpisodeMasterId": 1040421,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "蕾",
            "FontSize": 2,
            "Phrase": "傍から見ていた者よりも、舞台の上に立っていた者のほうが、/nより一層感じていたはずだ……白丸に引き上げられている、と。",
            "VoiceFileName": "10404210260",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
