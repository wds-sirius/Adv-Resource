            "EpisodeMasterId": 1040421,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "要",
            "FontSize": 2,
            "Phrase": "気付いたのね。……それに、いろはだけじゃないわ。/n蕾やカミラ、叶羽……あなたたちも、前より引き立って見えていたわ。",
            "VoiceFileName": "10404210140",
