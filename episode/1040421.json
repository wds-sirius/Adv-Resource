        {
            "Id": 1040421024,
            "EpisodeMasterId": 1040421,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "要",
            "FontSize": 2,
            "Phrase": "うちのボスってば、神出鬼没だからびっくりするわね……。/nけど、良かったわね、みんな！",
