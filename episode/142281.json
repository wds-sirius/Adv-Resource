            "EpisodeMasterId": 142281,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "カミラ",
            "FontSize": 2,
            "Phrase": "ほら、みんなどーいうのが喜ぶだろーとか、/nそーいうのちゃんと考えて選ばなきゃって思うからさ。",
