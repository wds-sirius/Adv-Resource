            "EpisodeMasterId": 142281,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "カミラの友人達",
            "FontSize": 2,
            "Phrase": "パーティー？",
            "VoiceFileName": "1422810050",
            "CharacterMotions": [],
