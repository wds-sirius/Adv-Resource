            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 1,
                    "SpineId": 40302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "403"
        },
        {
            "Id": 142281007,
            "EpisodeMasterId": 142281,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "カミラ",
            "FontSize": 2,
            "Phrase": "そのお祝いをするために、お店の候補選びと、/nどんなパーティーにするかを考えてたんだよねぇー。",
            "VoiceFileName": "1422810070",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 1,
                    "SpineId": 40302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "403"
        },
        {
            "Id": 142281008,
            "EpisodeMasterId": 142281,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "カミラの友人A",
            "FontSize": 2,
            "Phrase": "マジか！　なんかよく分かんないけど、色々すごくね？？/nみとりんがスゴいのは、テレビのインタビュー観て知ってたけど。",
            "VoiceFileName": "1422810080",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142281009,
            "EpisodeMasterId": 142281,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "カミラ",
            "FontSize": 2,
            "Phrase": "でしょ？　こんなんお祝いするしかないって感じなんだけどさー。/n肝心のお店が決まってないんだわ。",
            "VoiceFileName": "1422810090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 40302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "403"
        },
        {
            "Id": 142281010,
            "EpisodeMasterId": 142281,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "カミラの友人B",
            "FontSize": 2,
            "Phrase": "だったらさ、配信で聞いたらよくない？/n3人寄ればなんとかって言うじゃん。",
            "VoiceFileName": "1422810100",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142281011,
            "EpisodeMasterId": 142281,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "カミラ",
            "FontSize": 2,
            "Phrase": "あーね。/n3人寄れば文殊の知恵ってやつだ。",
            "VoiceFileName": "1422810110",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 15,
                    "LipSyncMasterId": 1,
                    "SpineId": 40302,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
