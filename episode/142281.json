        },
        {
            "Id": 142281006,
            "EpisodeMasterId": 142281,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "カミラ",
            "FontSize": 2,
            "Phrase": "そそ！　なんか、ウチらの劇団に世界演劇リーグから招待状が届いたり、/nみとりんはダイスターに選ばれたり……超すごいことが起きまくりだからさー。",
