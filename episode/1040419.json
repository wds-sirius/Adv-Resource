            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "どんどんお互い、気まずくなっていたのに……/n僕のせいで、みとちゃんを苦しめてしまって……本当にごめんなさいっっ！！",
