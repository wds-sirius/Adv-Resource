            "SpeakerIconId": "401"
        },
        {
            "Id": 1040419027,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "こんな未熟な僕ですが……/nみとちゃん、もう一度僕と、お友達になってくれませんか……？",
            "VoiceFileName": "10404190270",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 4,
