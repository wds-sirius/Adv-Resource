            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "不安にさせて、ごめんなさい……みとちゃん。/n僕が勝手に思い込んで行動したせいで、みとちゃんを追い詰めてしまいました。",
            "VoiceFileName": "10404190210",
            "CharacterMotions": [
