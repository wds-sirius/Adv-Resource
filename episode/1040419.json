            "GroupOrder": 28,
            "SpeakerName": "美兎",
            "FontSize": 2,
            "Phrase": "っ……うう……もちろん、だよ……！/n美兎のほうこそ、ごめんなさい……いろはちゃん……！",
            "BackgroundCharacterImageFileName": "142270_0",
            "VoiceFileName": "10404190280",
            "CharacterMotions": [],
            "SpeakerIconId": "402"
        },
        {
            "Id": 1040419029,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 29,
            "SpeakerName": "美兎",
            "FontSize": 2,
            "Phrase": "美兎……ずっといろはちゃんの傍にいたのに……/nそんな辛い思いしてるの、全然知らなくて……！",
            "BackgroundCharacterImageFileName": "142270_0",
            "VoiceFileName": "10404190290",
            "CharacterMotions": [],
            "SpeakerIconId": "402"
        },
        {
            "Id": 1040419030,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 30,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "い、いいんですよ……！/n話さなかった、僕がいけないんですし……。",
            "BackgroundCharacterImageFileName": "142270_0",
            "VoiceFileName": "10404190300",
            "CharacterMotions": [],
            "SpeakerIconId": "401"
        },
        {
            "Id": 1040419031,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 31,
            "SpeakerName": "美兎",
            "FontSize": 2,
            "Phrase": "ううん……美兎もね、いろはちゃんやみんなに、話してなかった事があるの。",
            "BackgroundCharacterImageFileName": "142270_0",
            "VoiceFileName": "10404190310",
            "CharacterMotions": [],
            "SpeakerIconId": "402"
        },
        {
            "Id": 1040419032,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 32,
            "SpeakerName": "美兎",
            "FontSize": 2,
            "Phrase": "すごく勝手だって思われるかもしれないけど……美兎はね、/n自分ひとりが評価されるのが、嫌だって思っちゃうの……。",
            "BackgroundCharacterImageFileName": "142270_0",
            "VoiceFileName": "10404190320",
            "CharacterMotions": [],
