            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "そんなの、絶対嫌です……。/n……だから、距離を置こうと思ったんです。",
            "VoiceFileName": "10404190200",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "HeadDirectionMasterId": 1,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
