            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "そのせいで、ひとりで空回りして、周りが見えなくなって、/nみんなの空気を壊してしまいました……皆さん、本当にごめんなさい！",
            "VoiceFileName": "10404190260",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 3,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
