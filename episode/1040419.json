        {
            "Id": 1040419012,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "……ちょっとだけ、僕の話をさせてください。/n僕は、皆さんも知っての通り、千寿家という役者の名門一家の娘です。",
            "VoiceFileName": "10404190120",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 4,
                    "SpineId": 40101,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 1040419013,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "ですが僕には、『センス』がありません。",
            "VoiceFileName": "10404190130",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 25,
                    "LipSyncMasterId": 4,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 1040419014,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "一生懸命に役を演じているつもりでも……、/nセンスがないからと、千寿家には、あまり期待してもらえませんでした。",
            "VoiceFileName": "10404190140",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "HeadDirectionMasterId": 4,
                    "LipSyncMasterId": 4,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 1040419015,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "それなのに、銀河座の児童部の頃は、千寿家の娘というだけで忖度されて……/n主役に選ばれてしまう事もありましたが、周りは納得していないようでした。",
            "VoiceFileName": "10404190150",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 1040419016,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "その時に演じたのが……『オズの魔法使い』のドロシーだったんです。/nですが三年後……同じ演目が決まった時、僕はドロシーになれませんでした。",
            "VoiceFileName": "10404190160",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "LipSyncMasterId": 4,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 1040419017,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "忖度されなければ、僕はドロシーにはなれないって分かって……/n僕にセンスがあったら……そんな気持ちを抱くようになっていました。",
            "VoiceFileName": "10404190170",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 25,
                    "LipSyncMasterId": 4,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 1040419018,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "ずっと心のどこかで、センスを持っている人が羨ましいって……だから、/nみとちゃんの事まで、羨ましく思ってしまって……。",
            "VoiceFileName": "10404190180",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "LipSyncMasterId": 4,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 1040419019,
            "EpisodeMasterId": 1040419,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "……昔、ひどい事を言って姉さんを傷つけてしまったのと同じように、/nこのままじゃ美兎ちゃんを傷つけてしまうかもしれない……。",
            "VoiceFileName": "10404190190",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "BodyMotionMasterId": 4,
                    "LipSyncMasterId": 4,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
