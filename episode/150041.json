        },
        {
            "Id": 150041026,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "いいんです。/n僕が頼りないのは事実ですから。",
            "VoiceFileName": "1500410250",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 201,
                    "BodyMotionMasterId": 12,
                    "LipSyncMasterId": 1,
                    "SpineId": 40134,
                    "CharacterAppearanceType": 0,
