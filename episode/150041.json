            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "望国士官",
            "FontSize": 2,
            "Phrase": "おはようございます、副司令。/n早速なのですが……実は帝国について、お耳に入れておきたい件が。",
            "VoiceFileName": "1500410080",
            "CharacterMotions": [],
