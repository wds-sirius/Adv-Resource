            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "望国士官",
            "FontSize": 2,
            "Phrase": "帝国圏のひとつが、何者かの手によって/n解放されたと報告がありました。",
            "VoiceFileName": "1500410100",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 150041012,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "何者か？",
