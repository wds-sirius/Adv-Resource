            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "だから、もっと多くの人に認めてもらえるように、/n精進していかなければですねっ！",
            "VoiceFileName": "1500410260",
            "CharacterMotions": [
