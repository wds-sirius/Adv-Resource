            "Order": 1,
            "GroupOrder": 1,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "（僕には昔、仲良くしていた姉さんが居ました）",
            "BackgroundImageFileName": "1050",
            "BgmFileName": "304",
