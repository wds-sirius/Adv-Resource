            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "みなさん、本日もご苦労様です。",
            "VoiceFileName": "1500410070",
            "CharacterMotions": [
