            "SpeakerIconId": "401"
        },
        {
            "Id": 150041013,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "望国士官",
            "FontSize": 2,
            "Phrase": "勢力の詳細は不明です。",
            "VoiceFileName": "1500410120",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 150041014,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "いずれにせよ、朗報には違いありませんね。",
            "VoiceFileName": "1500410130",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "HeadMotionMasterId": 1,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 1,
                    "SpineId": 40134,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 150041015,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "望国士官",
            "FontSize": 2,
            "Phrase": "ですが悪い報せもふたつ。",
            "VoiceFileName": "1500410140",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 150041016,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "望国士官",
            "FontSize": 2,
            "Phrase": "まず、各地で不吉な噂による混乱が広まっています。/n曰く『星辰が集い、星の神が降臨され救済なさる』とか。",
            "VoiceFileName": "1500410150",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 150041017,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "望国士官",
            "FontSize": 2,
            "Phrase": "もうひとつ。新妻艦隊が帝国に襲撃されました。/n我らの空域への侵攻が、明らかに勢いを増しております。",
            "VoiceFileName": "1500410160",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 150041018,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "……敵勢力解放の経緯と、/n星の神とやらの噂の流布元を調査しておいてください。",
            "VoiceFileName": "1500410170",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 7,
                    "LipSyncMasterId": 4,
                    "SpineId": 40134,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 150041019,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "それから、ただちに会議を行います。/n防衛機構を整備し、敵の動向を予測しなければ。",
            "VoiceFileName": "1500410180",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 107,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 150041020,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "望国士官",
            "FontSize": 2,
            "Phrase": "はいっ！",
            "VoiceFileName": "1500410190",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 150041021,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "望国兵Ａ",
            "FontSize": 2,
            "Phrase": "……事務処理副司令様のお出ましか。/n今日もまた慈善事業で予算と時間を食い潰すのかね。",
            "VoiceFileName": "1500410200",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 150041022,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "望国兵Ｂ",
            "FontSize": 2,
            "Phrase": "聞こえるぞ。",
            "VoiceFileName": "1500410210",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 150041023,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "望国兵Ａ",
            "FontSize": 2,
            "Phrase": "事実だろ。センスも使えない人間が上に立って、/nいったい何ができるってんだ？",
            "VoiceFileName": "1500410220",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 150041024,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "（……僕にセンスが使えたら、みんなに信頼してもらえるのでしょうか。/n　それにセンスさえあれば、あの時だって姉さんを……）",
            "VoiceFileName": "1500410230",
            "CharacterMotions": [
