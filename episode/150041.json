            "CharacterMotions": [],
            "SpeakerIconId": "401"
        },
        {
            "Id": 150041002,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 2,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "（でも……帝国の支配下で、僕たちの家は没落。/n　本来であれば、僕たちは、そのまま粛清される運命でした……）",
            "VoiceFileName": "1500410020",
            "CharacterMotions": [],
            "SpeakerIconId": "401"
        },
        {
            "Id": 150041003,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 3,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "（ですが、姉さんには兵としての能力がありました。/n　その姉さんが、帝国兵として仕えることで、千寿家は粛清を免れました）",
            "VoiceFileName": "1500410030",
            "CharacterMotions": [],
            "SpeakerIconId": "401"
        },
        {
            "Id": 150041004,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "（僕は……姉さんを犠牲にして、生き残ったんです。/n　もしもあの時、僕にもっと力があれば……姉さんだって……）",
            "VoiceFileName": "1500410040",
            "CharacterMotions": [],
            "SpeakerIconId": "401"
        },
        {
            "Id": 150041005,
            "EpisodeMasterId": 150041,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "（だからせめて、姉さんには、幸せでいて欲しい……。/n　この世界のどこかで健やかに暮らしていると、信じたいんです……）",
            "VoiceFileName": "1500410050",
            "CharacterMotions": [],
            "SpeakerIconId": "401"
        },
