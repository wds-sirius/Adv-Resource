            "GroupOrder": 13,
            "SpeakerName": "美兎",
            "FontSize": 2,
            "Phrase": "『わたしの名前はドロシー。カンザスに送ってもらうお願いをしに、/n　エメラルドの都の偉大なオズさまに会いに行くの』",
            "VoiceFileName": "10404220120",
            "CharacterMotions": [],
            "SpeakerIconId": "402"
        },
        {
            "Id": 1040422014,
            "EpisodeMasterId": 1040422,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "カミラ",
            "FontSize": 2,
            "Phrase": "『オズっていうのは誰なんだい？』",
            "VoiceFileName": "10404220130",
            "CharacterMotions": [],
            "SpeakerIconId": "403"
        },
        {
            "Id": 1040422015,
            "EpisodeMasterId": 1040422,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "美兎",
            "FontSize": 2,
            "Phrase": "『知らないの？』",
            "VoiceFileName": "10404220140",
            "CharacterMotions": [],
            "SpeakerIconId": "402"
        },
        {
            "Id": 1040422016,
            "EpisodeMasterId": 1040422,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "カミラ",
            "FontSize": 2,
            "Phrase": "『脳みそがないからね。/n　……オズにお願いすれば、おいらに脳みそをくれるかなあ』",
            "VoiceFileName": "10404220150",
            "CharacterMotions": [],
            "SpeakerIconId": "403"
        },
        {
            "Id": 1040422017,
            "EpisodeMasterId": 1040422,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "美兎",
            "FontSize": 2,
            "Phrase": "『きっともらえるわ！』",
            "VoiceFileName": "10404220160",
            "CharacterMotions": [],
            "SpeakerIconId": "402"
        },
        {
            "Id": 1040422018,
            "EpisodeMasterId": 1040422,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "蕾",
            "FontSize": 2,
            "Phrase": "『私は心がないんです、ブリキでできているから。/n　……もしオズにお願いすれば、私に心をくれるでしょうか』",
            "VoiceFileName": "10404220170",
            "CharacterMotions": [],
            "SpeakerIconId": "404"
        },
        {
            "Id": 1040422019,
            "EpisodeMasterId": 1040422,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "美兎",
            "FontSize": 2,
            "Phrase": "『オズならきっと叶えてくれる！』",
            "VoiceFileName": "10404220180",
            "CharacterMotions": [],
            "SpeakerIconId": "402"
        },
        {
            "Id": 1040422020,
            "EpisodeMasterId": 1040422,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "『僕はライオンだけど、勇気がない。/n　オズからもらえればいいけれど……』",
