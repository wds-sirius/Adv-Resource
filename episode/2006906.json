                }
            ],
            "SpeakerIconId": "401"
        },
        {
            "Id": 2006906008,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "そうそう。あの後、暴露大会みたいになってさ。/nまぁ、結局アタシは自分のことは話さなかったんだけど。",
            "VoiceFileName": "20069060080",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "HeadMotionMasterId": 1,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 1,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906009,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "あんな空気で言えることじゃないっていうか……、/nアタシとしてもああいう場で言いたい話でもないし？",
            "VoiceFileName": "20069060090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906010,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "そもそもずっと誰かに話す気だってないっていうか～……。",
            "VoiceFileName": "20069060100",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906011,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "ただ、そんなアタシがいろはの過去は一方的に知ってる。/n……それって、不公平じゃん。",
            "VoiceFileName": "20069060110",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 110,
                    "BodyMotionMasterId": 21,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906012,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "叶羽ちゃん……。",
            "VoiceFileName": "20069060120",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 500,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 40101,
