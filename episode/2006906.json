        },
        {
            "Id": 2006906013,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 13,
            "FontSize": 2,
            "Phrase": "",
            "BackgroundImageFileName": "1050",
            "BackgroundImageFileFadeType": 1,
            "BgmFileName": "9",
            "CharacterMotions": [],
            "FadeValue1": 0.20000000298023224,
            "FadeValue2": 0.30000001192092896,
            "FadeValue3": 0.20000000298023224
        },
        {
            "Id": 2006906014,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "当時のアタシは子役の仕事に、スカウトされたオリンポスの舞台で、/n目が回るほど忙しかった。",
            "VoiceFileName": "20069060130",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906015,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "それこそ、今じゃ考えられないくらい。/n昼寝する時間も、ゲームする時間だってなかった。",
            "VoiceFileName": "20069060140",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906016,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "けど、忙しいだけならまだよかった。/nやってれば終わるし、アタシ天才だし？",
            "VoiceFileName": "20069060150",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906017,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "……けど、そうやって乗り切れるほど簡単な世界じゃない。",
            "VoiceFileName": "20069060160",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906018,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "監督",
            "FontSize": 2,
            "Phrase": "『いや～、叶羽ちゃん良いねぇ～。/n　それに比べて……はぁ、他の子役はどうなってんの』",
            "VoiceFileName": "20069060170",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006906019,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "スタッフ",
            "FontSize": 2,
            "Phrase": "『そうっすねぇ……。一人降板でも良いんじゃないすか？/n　あの最年長の……もう落ち目でしょ』",
            "VoiceFileName": "20069060180",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006906020,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "監督",
            "FontSize": 2,
            "Phrase": "『あ～、それ俺も思ってたわ。/n　可哀想だけど、ありゃもう終わりだ』",
            "VoiceFileName": "20069060190",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006906021,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "子役Ａ",
            "FontSize": 2,
            "Phrase": "『アンタが……アンタが居たせいで……。/n　返してよ！　アタシの席！！　アタシの、アタシのだったのに！！！』",
            "VoiceFileName": "20069060200",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006906022,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "『……それ、監督に言いなさいよ。決めたのはあの人だし。/n　アタシに言ったところで、どうしようもないでしょ』",
            "VoiceFileName": "20069060210",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906023,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "嫌な物なんていくらでも見てきた。/nテレビでも……舞台でも。",
            "VoiceFileName": "20069060220",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906024,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 24,
            "FontSize": 2,
            "Phrase": "",
            "BackgroundImageFileName": "470",
            "BackgroundImageFileFadeType": 1,
            "CharacterMotions": [],
            "FadeValue1": 0.20000000298023224,
            "FadeValue2": 0.30000001192092896,
            "FadeValue3": 0.20000000298023224
        },
        {
            "Id": 2006906025,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "オリンポス劇団員",
            "FontSize": 2,
            "Phrase": "『あぁ、おばあさま。どうしておばあさまの耳はおっきいの？』",
            "VoiceFileName": "20069060230",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006906026,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "演出家",
            "FontSize": 2,
            "Phrase": "『はぁ……。次、本巣さん』",
            "VoiceFileName": "20069060240",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006906027,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "『……はい』",
            "VoiceFileName": "20069060250",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906028,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "『ああ……おばあさま、どうしておばあさまの耳はおっきいの？』",
            "VoiceFileName": "20069060260",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906029,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 29,
            "SpeakerName": "演出家",
            "FontSize": 2,
            "Phrase": "『……決めたわ。次の赤ずきんは本巣叶羽。/n　あなただから』",
            "VoiceFileName": "20069060270",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006906030,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 30,
            "SpeakerName": "演出家",
            "FontSize": 2,
            "Phrase": "『他はまったく話にならない。自分でも分かっているでしょう？/n　こんなたわけた演技を続けるなら、役者辞めなさい』",
            "VoiceFileName": "20069060280",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006906031,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 31,
            "SpeakerName": "オリンポス劇団員",
            "FontSize": 2,
            "Phrase": "『……ッッ！！　こんなの、ズルいよ。/n　そんなセンス、勝てっこない……インチキ、インチキだよ！！！！！』",
            "VoiceFileName": "20069060290",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006906032,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 32,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "『……はぁ。言い訳は済んだ？　それじゃ。/n　……そんなだから選ばれないのよ』",
            "VoiceFileName": "20069060300",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906033,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 33,
            "SpeakerName": "オリンポス劇団員",
            "FontSize": 2,
            "Phrase": "『……ッッ、ううっ、ううぅぅぅぅ……！！！』",
            "VoiceFileName": "20069060310",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006906034,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 34,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "気づけば同い年の子はみんな、役者も子役も辞めていた。/nまぁ、アタシのセンスを考えれば当たり前なんだけど。",
            "VoiceFileName": "20069060320",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906035,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 35,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "子役としても競争、舞台の上でも競争。/n恨まれることは常だった、だってアタシは天才だったし。",
            "VoiceFileName": "20069060330",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906036,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 36,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "アタシが潰した。……それを悪いとは思わない。/n思う所がないわけではないけど……そういう世界だから。",
            "BackgroundCharacterImageFileName": "142360_0",
            "VoiceFileName": "20069060340",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906037,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 37,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "いちいち、こんなことで思い悩んでいられない。",
            "BackgroundCharacterImageFileName": "142360_0",
            "VoiceFileName": "20069060350",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906038,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 38,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "踏み台にした側がくよくよ思い悩むなんて、/nそれこそ今まで潰してしまった子に失礼だから。",
            "BackgroundCharacterImageFileName": "142360_0",
            "VoiceFileName": "20069060360",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906039,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 39,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "普通の子供では居られない。アタシには才能がある。/n大人にならざるを得なかった。",
            "BackgroundCharacterImageFileName": "142360_0",
            "VoiceFileName": "20069060370",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906040,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 40,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "けど……心のどこかでは、同い年の他の子みたいに、/n子どもで居たいって……そう思ってた。",
            "BackgroundCharacterImageFileName": "142360_0",
            "VoiceFileName": "20069060380",
            "CharacterMotions": [],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006906041,
