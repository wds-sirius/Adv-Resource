        },
        {
            "Id": 2006906007,
            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "『オズの魔法使い』の時の……。",
            "VoiceFileName": "20069060070",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 7,
                    "LipSyncMasterId": 4,
                    "SpineId": 40101,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 2,
                    "CharacterLayerType": 1,
