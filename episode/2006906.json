            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "叶羽ちゃんからそういう話、聞くことってアリスの時以来、/nあまりなかったですし、無理して話す必要は……。",
            "VoiceFileName": "20069060050",
            "CharacterMotions": [
