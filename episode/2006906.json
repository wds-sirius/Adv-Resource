            "EpisodeMasterId": 2006906,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "前に、いろはの過去を話してもらったじゃん？",
            "VoiceFileName": "20069060060",
