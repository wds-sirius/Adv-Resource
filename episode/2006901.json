        },
        {
            "Id": 2006901004,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "あ～～～～、もう！　だから言わんこっちゃない！！/n相手が3人で来てるのに、対応人数減らして勝てるわけないじゃん！！",
            "VoiceFileName": "20069010030",
            "CharacterMotions": [
                {
