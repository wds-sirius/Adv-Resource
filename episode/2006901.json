        },
        {
            "Id": 2006901005,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "叶羽、ちょっといい？　入るわよ。",
            "VoiceFileName": "20069010040",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901006,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "あ、お母さん。なに、おやつの差し入れ？",
            "VoiceFileName": "20069010050",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 1,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006901007,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "違うわ……今日は相談。/nもうすぐ『こどもの日』でしょう？",
            "VoiceFileName": "20069010060",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901008,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "どこか、行きたいところはないかなと思って。",
            "VoiceFileName": "20069010070",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901009,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "はぇ？　こどもの日ぃ……？",
            "VoiceFileName": "20069010080",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006901010,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "そんなのあるわけないじゃ～～～ん。/n人混みは疲れるし、家でゲームしてるのが一番だって。",
            "VoiceFileName": "20069010090",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 79,
                    "BodyMotionMasterId": 27,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006901011,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "それが最高の休日の過ごし方でしょ～。",
            "VoiceFileName": "20069010100",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 21,
                    "LipSyncMasterId": 1,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006901012,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "はぁ……相変わらずねぇ。",
            "VoiceFileName": "20069010110",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901013,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "っていうか、お母さんからそんなこと言うなんて、珍しいじゃん。/nなに、どうしたの？",
            "VoiceFileName": "20069010120",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 7,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006901014,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "今回の仕事の調整がついたから、時間がつくれそうなのよ。/nせっかくだし、家族みんなで過ごせたらと思って。",
            "VoiceFileName": "20069010130",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901015,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "それに、今の叶羽……電姫で本当に頑張ってるから。",
            "VoiceFileName": "20069010140",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901016,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "え、知ってたの？　ていうか、見てたの？！",
            "VoiceFileName": "20069010150",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 500,
                    "BodyMotionMasterId": 5,
                    "LipSyncMasterId": 3,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006901017,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "ええ、娘の晴れ舞台ですもの。/n良い演技だったわ。",
            "VoiceFileName": "20069010160",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901018,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 18,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "ま、まぁね？　アタシにかかれば当然でしょ！/nそれにいろはたちも気合入ってたし！",
            "VoiceFileName": "20069010170",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 71,
                    "BodyMotionMasterId": 17,
                    "LipSyncMasterId": 1,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006901019,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "ふふっ、そうなのね。",
            "VoiceFileName": "20069010180",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901020,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "お父さんと話してね、叶羽のお祝いをしようかって。",
            "BgmFileName": "8",
            "VoiceFileName": "20069010190",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901021,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "それに、前は子役の仕事だったり、オリンポスで忙しかったでしょう？/n家族でゆっくり出かけるような暇を作ってあげられなかったから。",
            "VoiceFileName": "20069010200",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901022,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "あ……。",
            "VoiceFileName": "20069010210",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006901023,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "だから、今からでもどうかな……なんて。",
            "VoiceFileName": "20069010220",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901024,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "……。",
            "VoiceFileName": "20069010230",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 70,
                    "BodyMotionMasterId": 13,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006901025,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "でも無理にとは言わないわ。/nせっかくのこどもの日ですもの。",
            "VoiceFileName": "20069010240",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901026,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "叶羽が家でゲームがしたいってことなら、/nそれも良いと思うし。",
            "VoiceFileName": "20069010250",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006901027,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "……まぁ、お母さんがそこまで言うなら、/n考えてあげなくもない、かな。",
            "VoiceFileName": "20069010260",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 1,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 2006901028,
            "EpisodeMasterId": 2006901,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "叶羽の母親",
            "FontSize": 2,
            "Phrase": "そう？　嬉しいわ。じゃあ行きたい所考えておいてね。",
            "VoiceFileName": "20069010270",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
