                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "301"
        },
        {
            "Id": 2006903027,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "盗み聞きとは、感心しませんね。/n……貴女が気にすることではありません。",
            "VoiceFileName": "20069030220",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006903028,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "暦",
            "FontSize": 2,
            "Phrase": "おばあさま……。……お言葉ですが、銀河座には私が居ます。/nいろはさんを再び銀河座に入れる意義が見出せません。",
            "VoiceFileName": "20069030230",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 104,
                    "BodyMotionMasterId": 14,
                    "LipSyncMasterId": 3,
                    "SpineId": 30101,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "301"
        },
        {
            "Id": 2006903029,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 29,
            "SpeakerName": "暦",
            "FontSize": 2,
            "Phrase": "いろはさんが銀河座を辞めると言った時、おばあさまは了承された。/nだからこそ、これまでいろはさんを放任していたのでしょう？",
            "VoiceFileName": "20069030240",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 13,
                    "LipSyncMasterId": 4,
                    "SpineId": 30101,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "301"
        },
        {
            "Id": 2006903030,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 30,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "そう簡単な話ではありませんよ、暦さん。千寿の名を負って出たのであれば、/nいろはさんは千寿家の役者として世間に見られるでしょう。",
            "VoiceFileName": "20069030250",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006903031,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 31,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "小劇団かつ邪道の演劇で多くの人々の目につくようになってしまった。/nそれは私たち千寿家の格を落としかねない、一大事なのです。",
            "VoiceFileName": "20069030260",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006903032,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 32,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "ならば、せめて千寿の名に恥じない劇団へと彼女を移すべき。/n……千寿家の役者であるならば、分かっているはずですが？",
            "VoiceFileName": "20069030270",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006903033,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 33,
            "SpeakerName": "暦",
            "FontSize": 2,
            "Phrase": "……っ。",
            "VoiceFileName": "20069030280",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 25,
                    "SpineId": 30101,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "301"
        },
        {
            "Id": 2006903034,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 34,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "ダイスターの祭典もあるのでしょう？/nこのようなことで気を揉んでいる暇が貴女にはあるのですか？",
            "VoiceFileName": "20069030290",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006903035,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 35,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "馴れ合わず、ただひたすら天頂の星であり続けること。/nそれが千寿家の役者である貴女の責務です。",
            "VoiceFileName": "20069030300",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006903036,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 36,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "外的要因……それも身内のことで気を揉むなど、/n自覚が足りていない、笑止千万です。",
            "VoiceFileName": "20069030310",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
