        {
            "Id": 2006903007,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "幸い、どうやら演技は見れるようになったようですし、/n天頂の星には手は届かずとも横で輝きに照らされる程度は出来るでしょう。",
            "VoiceFileName": "20069030050",
            "CharacterMotions": [],
