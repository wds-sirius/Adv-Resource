        },
        {
            "Id": 2006903009,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "お望みでしたら私から口利きいたしましょうか？/nセンスを持った役者たちに囲まれて、世界演劇リーグへと足を進めた。",
            "VoiceFileName": "20069030070",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006903010,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "であれば、銀河座に行ったところで変わりないでしょう。/n寧ろ規模は銀河座の方が大きい。",
            "VoiceFileName": "20069030080",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 2006903011,
            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "暦といろはの祖母",
            "FontSize": 2,
            "Phrase": "貴女は千寿を名乗り、このような劇団の舞台に出た。/nそして、今注目を集めてしまっている……その意味をよく考えなさい。",
            "VoiceFileName": "20069030090",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
