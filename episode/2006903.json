            "GroupOrder": 8,
            "SpeakerName": "いろは",
            "FontSize": 2,
            "Phrase": "それは……。",
            "VoiceFileName": "20069030060",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 25,
                    "LipSyncMasterId": 4,
