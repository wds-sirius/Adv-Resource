            "EpisodeMasterId": 2006903,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "暦",
            "FontSize": 2,
            "Phrase": "一体、どういう風の吹き回しですか？/n……いろはさんを、銀河座にだなんて。",
            "VoiceFileName": "20069030210",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 110,
                    "BodyMotionMasterId": 3,
                    "LipSyncMasterId": 4,
                    "SpineId": 0,
                    "CharacterAppearanceType": 0,
