                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361005,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 5,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "この間言ってたやつなんだけど……どこへ行きたいか決めた？",
            "VoiceFileName": "1423610050",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361006,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 6,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "へ？　なんの話？",
            "VoiceFileName": "1423610060",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 500,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361007,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 7,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "ほら、この間話したじゃない。/n今度の子どもの日、休みだからどっか行こうって。",
            "VoiceFileName": "1423610070",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361008,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 8,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "あー、そんな話してたわねぇ～。/nぶっちゃけアタシは、家でダラダラしてたいのは変わらないんだけど。",
            "VoiceFileName": "1423610080",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 102,
                    "BodyMotionMasterId": 6,
                    "LipSyncMasterId": 1,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361009,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 9,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "たまには外で遊ぶのも楽しいと思うわよ？",
            "VoiceFileName": "1423610090",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361010,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 10,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "せっかく家族全員が揃うお休みじゃない。/nだから今回くらいは……ね？　いいでしょ、叶羽。",
            "VoiceFileName": "1423610100",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361011,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 11,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "えぇ～……。",
            "VoiceFileName": "1423610110",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 25,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361012,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 12,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "（今日はやけにしつこいなー……。/n　行きたいとことか、マジでなんにもないんだけど……）",
            "VoiceFileName": "1423610120",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361013,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 13,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "（でも、なかなか引き下がる気なさそうだし……。/n　うーん……仕方ない、ここは…………）",
            "VoiceFileName": "1423610130",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 6,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361014,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 14,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "……じゃあ、アタシが普段しないような、/n違った体験ができる場所ならどこでもいいかなぁ～。",
            "VoiceFileName": "1423610140",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 21,
                    "LipSyncMasterId": 1,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361015,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 15,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "あら、そう！/n分かったわ。お父さんとお母さんで、何か探してみるわね。",
            "VoiceFileName": "1423610150",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361016,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 16,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "は～い、お願いしま～す。",
            "VoiceFileName": "1423610160",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 20,
                    "LipSyncMasterId": 1,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361017,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 17,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "（しゃーない……一日潰れるけど、たまには家族サービスも必要よね。/n　ま、当日もテキトーにやり過ごそーっと）",
            "VoiceFileName": "1423610170",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 71,
