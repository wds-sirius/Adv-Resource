            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 32,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "ええぇ……。",
            "VoiceFileName": "1423610310",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 25,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
