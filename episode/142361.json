        {
            "Id": 142361019,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 19,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "……いや、いやいや……確かにね？/n『普段と違った体験ができる場所なら、どこでもいい』って言ったけどさ？",
            "VoiceFileName": "1423610180",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 74,
                    "BodyMotionMasterId": 3,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
