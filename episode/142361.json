            "Order": 1,
            "GroupOrder": 3,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "叶羽～？　今ちょっといいかしら？",
            "VoiceFileName": "1423610030",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361004,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 4,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "んー、別にいいけどー。",
            "VoiceFileName": "1423610040",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 1,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
