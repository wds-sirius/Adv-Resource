            "SpeakerIconId": "405"
        },
        {
            "Id": 142361020,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 20,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "よりによって、なんでこれなのよーーー！？",
            "VoiceFileName": "1423610190",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 25,
                    "LipSyncMasterId": 3,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361021,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 21,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "えー？　楽しそうでいいじゃない？　ジップスライドよ？/nほら、叶羽のやってるゲームとかでもよくある……。",
            "VoiceFileName": "1423610200",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361022,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 22,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "ゲームのキャラは、特殊なスキルを使ってるからでぇ～……！/nアタシは普通の人間なの！　こんな高い所から飛んでいい体じゃないの！",
            "VoiceFileName": "1423610210",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 73,
                    "BodyMotionMasterId": 2,
                    "LipSyncMasterId": 3,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361023,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 23,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "でも、これなら叶羽だって、/n日頃は味わえないような、非日常的な体験ができるわよ！",
            "VoiceFileName": "1423610220",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361024,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 24,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "いやいや……アタシが言ったのは、こんな肉体派のやつじゃなくて……。/nもっとこう……楽ちんで、のんびり出来るような乗り物とかさぁ～……。",
            "VoiceFileName": "1423610230",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 12,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361025,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 25,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "まあまあ。/nたまにはこういうのも、いいじゃないの。",
            "VoiceFileName": "1423610240",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361026,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 26,
            "SpeakerName": "叶羽の父",
            "FontSize": 2,
            "Phrase": "やってみたら案外、爽快かもしれないよ。/nほら、父さんも母さんも居るんだ、心配いらないぞ？",
            "VoiceFileName": "1423610250",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361027,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 27,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "そんなこと言われても……ジップスライド自体は一人用でしょ？/nふたりとも、いざって時には助けに来られないじゃない……。",
            "VoiceFileName": "1423610260",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 400,
                    "BodyMotionMasterId": 11,
                    "LipSyncMasterId": 4,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361028,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 28,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "大丈夫よ、ちゃんと安全装置もついてるみたいだし。/n下にはネットだって張られてるわ。もし落ちても平気よ！",
            "VoiceFileName": "1423610270",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361029,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 29,
            "SpeakerName": "叶羽",
            "FontSize": 2,
            "Phrase": "いやいやいや、落ちる前提じゃないの！/n無理だって！　トラウマ植え付けられたらどうすんのよー！",
            "VoiceFileName": "1423610280",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 302,
                    "BodyMotionMasterId": 2,
                    "LipSyncMasterId": 3,
                    "SpineId": 40501,
                    "CharacterAppearanceType": 0,
                    "CharacterPosition": 3,
                    "CharacterLayerType": 1,
                    "SpineSize": 2
                }
            ],
            "SpeakerIconId": "405"
        },
        {
            "Id": 142361030,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 30,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "ほら、四の五の言わないの！　なんでも経験よ。",
            "VoiceFileName": "1423610290",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
            "Id": 142361031,
            "EpisodeMasterId": 142361,
            "Order": 1,
            "GroupOrder": 31,
            "SpeakerName": "叶羽の母",
            "FontSize": 2,
            "Phrase": "それに、怖がりながらも、/n大きい声を出して思いっきり騒ぐと、ストレス発散にもなるんだから！",
            "VoiceFileName": "1423610300",
            "CharacterMotions": [],
            "SpeakerIconId": "1"
        },
        {
