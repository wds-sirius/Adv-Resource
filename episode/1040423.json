            "EpisodeMasterId": 1040423,
            "Order": 1,
            "GroupOrder": 33,
            "SpeakerName": "要",
            "FontSize": 2,
            "Phrase": "その分、私たち運営側も気を引き締めないとですね……。/nあの子たちが目指すものに恥じないように。",
            "VoiceFileName": "10404230330",
            "CharacterMotions": [
