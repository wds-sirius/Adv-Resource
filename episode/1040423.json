            "SpeakerName": "マチコ",
            "FontSize": 2,
            "Phrase": "――私が見込んだ以上に、あの子たちは成長したな。",
            "VoiceFileName": "10404230310",
            "CharacterMotions": [
                {
                    "slotNumber": 1,
                    "FacialExpressionMasterId": 103,
