            "EpisodeMasterId": 1040423,
            "Order": 1,
            "GroupOrder": 32,
            "SpeakerName": "マチコ",
            "FontSize": 2,
            "Phrase": "少なくとも、今回の舞台で電姫は、/nこれまでの客層とは違う客層にも存在感を発揮出来ただろう。",
            "VoiceFileName": "10404230320",
            "CharacterMotions": [
